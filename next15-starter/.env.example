# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WordPress base URL and GraphQL endpoint
NEXT_PUBLIC_WORDPRESS_URL=https://example.com
WORDPRESS_GRAPHQL_ENDPOINT=https://example.com/graphql
NEXT_PUBLIC_WORDPRESS_HOSTNAME=example.com
NEXT_PUBLIC_IMAGE_HOSTNAMES=example.com,cdn.example.com
WORDPRESS_AUTH_TOKEN=
WORDPRESS_REVALIDATION_SECRET=

# Preview secret for Next.js draft mode route handler
WORDPRESS_PREVIEW_SECRET=replace-with-secure-random-value

# Contact route handler defaults
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=no-reply@example.com
CONTACT_REPLY_TO_EMAIL=
CONTACT_SUBJECT_PREFIX=[Website]

# Resend API key for contact delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Optional Cloudflare Turnstile public key for frontend widgets
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional Cloudflare Turnstile server verification
TURNSTILE_SECRET_KEY=
